# 2nd Act Capital — environment variables (no values committed)
# Copy the relevant section into apps/web/.env.local or your API host config.

# --- Web (apps/web) — Auth0 Next.js SDK ---
APP_BASE_URL=
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_SECRET=
# Base URL of the FastAPI backend (used by the web app)
NEXT_PUBLIC_API_URL=
# Auth0 API audience the web app requests an access token for
AUTH0_AUDIENCE=

# --- API (apps/api) ---
DATABASE_URL=
AUTH0_DOMAIN=
AUTH0_AUDIENCE=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
